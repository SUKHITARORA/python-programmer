import pygame
pygame.init()
screen=pygame.display.set_mode((640,480))
pygame.display.set_caption('my first game screen')
done=False
while not done:
    for event in pygame.event.get():
        if event.type==pygame.quit:
            done=True
    pygame.draw.rect(screen,(0,111,255),pygame.Rect(30,30,90,60))
    pygame.display.flip()
