from tkinter import *
window=Tk()
window.geometry("400x400")
window.title("interest calculator")
l1=Label(text="interest calculator")
l1.pack()
l2=Label(text="enter your amount")
l2.pack()
t1=Entry()
t1.pack()
l3=Label(text="enter the interest percentage")
l3.pack()
t2=Entry()
t2.pack()
def calculate():
    amount=int(t1.get())
    interestpercentage=int(t2.get())
    total=amount+(interestpercentage*(amount/100))
    t.insert(END,"the total amount you will get is ")
    t.insert(END,total)
b1=Button(text="calculate",command=calculate)
b1.pack()
t=Text(height = 3)
t.pack()
window.mainloop()
